# Database
DATABASE_URL=sqlite:///./cloudmart.db

# Security
SECRET_KEY=cloudmart-secret-key-change-in-production

# Email Configuration (Optional - for Day End Reports)
# Leave blank to disable email notifications
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Note: For Gmail, use App Password, not your regular password
# Generate here: https://myaccount.google.com/apppasswords
